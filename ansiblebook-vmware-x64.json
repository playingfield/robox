            "start_retry_timeout": "15m",
            "expect_disconnect": "true",
            "only": [
                "ansiblebook-debian13-vmware-x64"
            ]
        }
    ],
    "builders": [
        {
            "type": "vmware-iso",
            "name": "ansiblebook-alma9-vmware-x64",
