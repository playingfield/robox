                "sed -i -e \"/rc-service/d\" /sbin/setup-sshd<enter><wait>",
                "source generic.alpine319.vagrant.cfg<enter><wait>",
                "printf \"vagrant\\nvagrant\\n\" | sh /sbin/setup-alpine -f /root/generic.alpine319.vagrant.cfg && ",
