            "vmdk_name": "ansiblebook-alma9-vmware-x64",
            "output_directory": "output/ansiblebook-alma9-vmware-x64",
            "boot_wait": "20s",
            "boot_keygroup_interval": "1s",
            "boot_command": [
                "<tab> net.ifnames=0 inst.text inst.ks=http://{{ .HTTPIP }}:{{ .HTTPPort }}/generic.alma9.vagrant.x64.ks vga=792 <enter><wait>"
            ],
            "disk_size": 131072,
