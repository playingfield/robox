                "scripts/alma9/dnf.sh",
                "scripts/alma9/base.sh",
                "scripts/alma9/reboot.sh"
            ],
            "execute_command": "{{.Vars}} /bin/bash '{{.Path}}'",
            "start_retry_timeout": "15m",
            "expect_disconnect": "true",
            "only": [
                "ansiblebook-alma9-vmware-x64"
            ]
        },
        {
            "type": "shell",
            "timeout": "120m",
