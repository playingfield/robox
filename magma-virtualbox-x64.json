    "builders": [
        {
            "type": "virtualbox-iso",
            "name": "magma-arch-virtualbox-x64",
            "vm_name": "magma-arch-virtualbox-x64",
            "output_directory": "output/magma-arch-virtualbox-x64",
            "boot_wait": "1s",
            "boot_keygroup_interval": "1s",
            "boot_command": [
                "<tab><wait><tab><wait><tab><wait><tab><wait><tab><wait>",
                "<tab><wait><tab><wait><tab><wait><tab><wait><tab><wait>",
                "<tab><wait><tab><wait><tab><wait><tab><wait><tab><wait>",
                "<tab><wait><tab><wait><tab><wait><tab><wait><tab><wait>",
                "<tab><wait><tab><wait><tab><wait><tab><wait><tab><wait>",
                "<tab><wait><tab><wait><tab><wait><tab><wait><tab><wait>",
                "<tab><wait><tab><wait><tab><wait><tab><wait><tab><wait>",
                "<tab><wait><tab><wait><tab><wait><tab><wait><tab><wait>",
                "<tab><wait><tab><wait><tab><wait><tab><wait><tab><wait>",
                "<tab><wait><tab><wait><tab><wait><tab><wait><tab><wait>",
                "<tab><wait><tab><wait><tab><wait><tab><wait><tab><wait>",
                "<tab><wait><tab><wait><tab><wait><tab><wait><tab><wait>",
                "<spacebar>net.ifnames=0 biosdevname=0 systemd.mask=sshd.service<enter>",
                "<wait10><wait10><wait10><wait10><wait10><wait10>",
                "<wait10><wait10><wait10><wait10><wait10><wait10>",
                "<wait10><wait10><wait10><wait10><wait10><wait10>",
                "sed -i 's/[#]\\?DNSSEC=.*/DNSSEC=false/g' /etc/systemd/resolved.conf<enter><wait>",
                "systemctl restart systemd-resolved<enter><wait>",
                "systemctl restart dhcpcd<enter><wait>",
                "curl -O 'http://{{.HTTPIP}}:{{.HTTPPort}}/magma.arch.vagrant{,.chroot}.sh'<enter><wait>",
                "bash magma.arch.vagrant.sh < magma.arch.vagrant.chroot.sh && systemctl reboot<enter>"
            ],
            "disk_size": 131072,
            "cpus": 2,
            "memory": 2048,
            "vboxmanage": [
                [
                    "modifyvm",
                    "{{.Name}}",
                    "--vram",
                    "64"
                ]
            ],
            "hard_drive_interface": "sata",
            "guest_os_type": "ArchLinux_64",
            "http_directory": "http",
            "headless": true,
            "vrdp_bind_address": "127.0.0.1",
            "vrdp_port_min": 11000,
            "vrdp_port_max": 12000,
            "iso_url": "https://mirrors.kernel.org/archlinux/iso/latest/archlinux-2025.02.01-x86_64.iso",
            "iso_checksum": "sha256:45f097416d604ac20e982d2137534ffbe00990ba36dcb9bd259c05a4515f20cd",
            "ssh_username": "root",
            "ssh_password": "vagrant",
            "ssh_port": 22,
            "ssh_handshake_attempts": 1000,
            "ssh_timeout": "3600s",
            "shutdown_command": "systemctl poweroff",
            "guest_additions_url": "https://download.virtualbox.org/virtualbox/7.0.14/VBoxGuestAdditions_7.0.14.iso",
            "guest_additions_sha256": "0efbcb9bf4722cb19292ae00eba29587432e918d3b1f70905deb70f7cf78e8ce",
            "guest_additions_path": "VBoxGuestAdditions.iso",
            "guest_additions_mode": "upload",
            "virtualbox_version_file": "VBoxVersion.txt"
        },
        {
            "type": "virtualbox-iso",
            "name": "magma-gentoo-virtualbox-x64",
            "vm_name": "magma-gentoo-virtualbox-x64",
            "output_directory": "output/magma-gentoo-virtualbox-x64",
            "boot_wait": "180s",
            "boot_keygroup_interval": "1s",
            "boot_command": [
                "passwd root<enter><wait><wait><wait>",
                "vagrant<enter><wait>",
                "vagrant<enter><wait>",
                "curl -O 'http://{{ .HTTPIP }}:{{ .HTTPPort }}/magma.gentoo.vagrant{,.chroot}.x64.sh'<enter><wait>",
                "bash magma.gentoo.vagrant.x64.sh<enter>"
            ],
            "disk_size": 131072,
            "cpus": 8,
            "memory": 8192,
            "vboxmanage": [
                [
                    "modifyvm",
                    "{{.Name}}",
                    "--vram",
                    "64"
                ]
            ],
            "hard_drive_interface": "sata",
            "guest_os_type": "Gentoo_64",
            "http_directory": "http",
            "headless": true,
            "vrdp_bind_address": "127.0.0.1",
            "vrdp_port_min": 11000,
            "vrdp_port_max": 12000,
            "iso_url": "https://mirrors.kernel.org/gentoo/releases/amd64/autobuilds/current-install-amd64-minimal/install-amd64-minimal-20250216T164837Z.iso",
            "iso_checksum": "sha256:c7da771b38b7d564caadf6a3bc4334a19b2b9a3c95c46d3b7ab15fcac18e6e7f",
            "ssh_username": "root",
            "ssh_password": "vagrant",
            "ssh_port": 22,
            "ssh_handshake_attempts": 1000,
            "ssh_timeout": "9800s",
            "shutdown_command": "shutdown -hP now",
            "guest_additions_url": "https://download.virtualbox.org/virtualbox/7.0.14/VBoxGuestAdditions_7.0.14.iso",
            "guest_additions_sha256": "0efbcb9bf4722cb19292ae00eba29587432e918d3b1f70905deb70f7cf78e8ce",
            "guest_additions_path": "VBoxGuestAdditions.iso",
            "guest_additions_mode": "upload",
            "virtualbox_version_file": "VBoxVersion.txt"
        },
        {
            "type": "virtualbox-iso",
            "name": "magma-debian11-virtualbox-x64",
            "vm_name": "magma-debian11-virtualbox-x64",
            "output_directory": "output/magma-debian11-virtualbox-x64",
            "boot_wait": "10s",
            "boot_keygroup_interval": "1s",
            "boot_command": [
                "<esc><wait><esc><wait><esc><wait><esc><wait><esc><wait><esc><wait>",
                "<esc><wait><esc><wait><esc><wait><esc><wait><esc><wait><esc><wait>",
                "<esc><wait><esc><wait><esc><wait><esc><wait><esc><wait><esc><wait>",
                "<esc><wait><esc><wait><esc><wait><esc><wait><esc><wait><esc><wait>",
                "<esc><wait><esc><wait><esc><wait><esc><wait><esc><wait><esc><wait>",
                "<esc><wait><esc><wait><esc><wait><esc><wait><esc><wait><esc><wait>",
                "<esc><wait><esc><wait><esc><wait><esc><wait><esc><wait><esc><wait>",
                "<esc><wait><esc><wait><esc><wait><esc><wait><esc><wait><esc><wait>",
                "<esc><wait><esc><wait><esc><wait><esc><wait><esc><wait><esc><wait>",
                "<esc><wait><esc><wait><esc><wait><esc><wait><esc><wait><esc><wait>",
                "auto ",
                "ipv6.disable_ipv6=1 net.ifnames=0 biosdevname=0 preseed/url=http://{{.HTTPIP}}:{{.HTTPPort}}/magma.debian11.vagrant.cfg ",
                "<enter>"
            ],
            "disk_size": 131072,
            "cpus": 2,
            "memory": 2048,
            "vboxmanage": [
                [
                    "modifyvm",
                    "{{.Name}}",
                    "--vram",
                    "64"
                ]
            ],
            "hard_drive_interface": "sata",
            "guest_os_type": "Debian_64",
            "http_directory": "http",
            "headless": true,
            "vrdp_bind_address": "127.0.0.1",
            "vrdp_port_min": 11000,
            "vrdp_port_max": 12000,
            "iso_url": "https://cdimage.debian.org/cdimage/archive/11.8.0/amd64/iso-cd/debian-11.8.0-amd64-netinst.iso",
            "iso_checksum": "sha256:d7a74813a734083df30c8d35784926deaa36bc41e5c0766388e9f591ab056b72",
            "ssh_username": "root",
            "ssh_password": "vagrant",
            "ssh_port": 22,
            "ssh_handshake_attempts": 1000,
            "ssh_timeout": "3600s",
            "shutdown_command": "echo 'vagrant' | sudo -S shutdown -P now",
            "guest_additions_url": "https://download.virtualbox.org/virtualbox/6.1.36/VBoxGuestAdditions_6.1.36.iso",
            "guest_additions_sha256": "c987cdc8c08c579f56d921c85269aeeac3faf636babd01d9461ce579c9362cdd",
            "guest_additions_path": "VBoxGuestAdditions.iso",
            "guest_additions_mode": "upload",
            "virtualbox_version_file": "VBoxVersion.txt"
        }
    ],
