            "temp_path": "output/",
            "output_directory": "output/magma-arch-hyperv-x64",
            "boot_wait": "1s",
            "boot_keygroup_interval": "1s",
            "boot_command": [
                "<tab><wait><tab><wait><tab><wait><tab><wait><tab><wait>",
                "<tab><wait><tab><wait><tab><wait><tab><wait><tab><wait>",
                "<tab><wait><tab><wait><tab><wait><tab><wait><tab><wait>",
